{
  "name": "ai-assistant-server",
  "version": "1.0.0",
  "private": true,
  "description": "AI-powered job matching ai-assistant server — AWS ECS + Bedrock + RapidAPI JSearch",
  "scripts": {
    "dev": "cd src && npm run dev",
    "build": "cd src && npm run build",
    "start": "cd src && npm run start",
    "install:all": "npm install && cd src && npm install && cd ../infra/modules/lambda && npm install",
    "docker:build": "docker build -t ai-assistant-server .",
    "docker:run": "docker run -p 3000:3000 --env-file .env ai-assistant-server",
    "tf:init": "cd infra/environments/prod && terraform init",
    "tf:plan": "cd infra/environments/prod && terraform plan",
    "tf:apply": "cd infra/environments/prod && terraform apply",
    "tf:destroy": "cd infra/environments/prod && terraform destroy",
    "deploy": "bash deploy.sh"
  },
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "typescript": "^5.0.0"
  }
}